#include <stdio.h>
#include "function_divisao.c"

int main() {
    float num1, num2;
    int opcao;

    printf("Digite o primeiro numero: ");
    scanf("%f", &num1);

    printf("Digite o segundo numero: ");
    scanf("%f", &num2);

    printf("\nEscolha a operacao:\n");
    printf("1 - Soma\n");
    printf("2 - Subtraçao\n");
    printf("3 - Divisao\n");
    printf("Opçao: ");
    scanf("%d", &opcao);

    switch(opcao) {
        case 1:
            printf("Resultado: %.2f\n", num1 + num2);
            break;

        case 2:
            printf("Resultado: %.2f\n", num1 - num2);
            break;

        case 3:
            printf("Resultado: %.2f\n", dividir(num1, num2));
            break;

        default:
            printf("Opção inválida!\n");
    }

    return 0;
}
